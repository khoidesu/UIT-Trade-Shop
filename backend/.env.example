# Backend runtime
HOST=0.0.0.0
PORT=8000

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority
MONGODB_DB=shopee_clone
MONGODB_COLLECTION=products

# Admin
ADMIN_REGISTRATION_CODE=change-me

# CORS (comma separated, no trailing slash)
FRONTEND_ORIGINS=https://your-frontend.netlify.app,https://yourdomain.com

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-mail@gmail.com
SMTP_PASS=your-app-password
